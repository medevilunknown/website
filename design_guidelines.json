{
  "theme": "dark",
  "archetype": "Futuristic OS (Blue/Black/White)",
  "typography": {
    "heading_font": "Chakra Petch",
    "heading_weights": [600, 700],
    "body_font": "IBM Plex Sans",
    "body_weights": [400, 500],
    "mono_font": "JetBrains Mono",
    "mono_weights": [400, 700],
    "scale": {
      "h1": "text-5xl sm:text-6xl+ tracking-tighter",
      "h2": "text-3xl sm:text-4xl tracking-tight",
      "h3": "text-xl sm:text-2xl",
      "body": "text-base leading-relaxed",
      "code": "text-xs sm:text-sm tracking-widest uppercase"
    }
  },
  "colors": {
    "background": {
      "primary": "#060708",
      "panel": "#0C0E12",
      "elevated": "#12161D"
    },
    "text": {
      "primary": "#E8EEF5",
      "muted": "#8B9BB4",
      "inverse": "#060708"
    },
    "brand": {
      "accent_core": "#3B82F6",
      "accent_glow": "#60A5FA",
      "border_hairline": "#1E293B"
    }
  },
  "layout_and_surfaces": {
    "glassmorphism": "backdrop-blur-xl bg-[#0C0E12]/60 border border-white/5 shadow-[0_0_30px_rgba(59,130,246,0.05)]",
    "panel_radius": "rounded-none",
    "spacing_scale": "generous",
    "container_padding": "p-8 md:p-12"
  },
  "components": {
    "radial_menu": {
      "radius": "250px",
      "item_count": 6,
      "items": ["Vision", "Projects", "People", "Nexus", "About", "Careers"],
      "hover_effect": "scale-110 drop-shadow-[0_0_15px_rgba(59,130,246,0.8)]",
      "icons": "lucide-react (e.g., Eye, Grid, Users, Cpu, Info, Briefcase)"
    },
    "boot_loader": {
      "stages": [
        "Blinking cursor",
        "Pseudo-code initialization log",
        "ASCII OPYO logo render",
        "Percentage counter 0-100% with SKIP button"
      ]
    },
    "careers_form": {
      "shadcn_components": ["Form", "Input", "Textarea", "Button"],
      "aesthetic": "Wrapped in code-as-content mono text block, minimal borders, glow on focus"
    }
  },
  "motion_and_3d": {
    "background_scene": {
      "type": "Neural Network Constellation",
      "particle_count": 2000,
      "colors": ["#3B82F6", "#60A5FA"],
      "interaction": "Mouse cursor repels nodes (spring physics), continuous slow rotation",
      "camera": "PerspectiveCamera, slight parallax movement on pointer move",
      "lighting": "Ambient soft blue + directional white"
    },
    "transitions": {
      "page_enter": "GSAP zoom-in on central radial hub, scaling to infinity, fading into section content",
      "scroll": "Lenis smooth scrolling with momentum"
    }
  },
  "audio": {
    "hover": "Sine wave, 800Hz, 50ms, low volume",
    "click": "Triangle wave, 200Hz descending to 100Hz, 150ms",
    "boot": "Fast mechanical tick sequence"
  },
  "testing": {
    "data_testid_convention": "kebab-case, role-based (e.g., 'radial-menu-item-vision', 'careers-submit-button', 'boot-skip-button')"
  },
